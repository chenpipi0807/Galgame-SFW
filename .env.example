# ⚠️ 说明：从此版本起，API「连接」配置改存本地数据库（管理后台 → API 配置 增删/启用）。
#    本文件中的 provider 变量仅用于【旧版升级时一次性迁移】；新安装无需填写。
#    Agnes 免费连接已内置在程序中，开箱即用，无需在此填 Key。

# ===== LLM 模型配置（旧版迁移用）=====
# 可选: agnes / deepseek
LLM_PROVIDER=agnes

# Agnes（已内置，无需填写；留空即可）
AGNES_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ===== 图像生成配置 =====
# 可选: agnes / gemini / gpt-image-2
IMG_PROVIDER=agnes

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-3.1-flash-image-preview

# AIHubMix (gpt-image-2)
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
